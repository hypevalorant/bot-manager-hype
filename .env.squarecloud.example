NODE_ENV=production
PORT=80
HOST=0.0.0.0
APP_BASE_URL=https://bot-manager-hype-api.squareweb.app
ADMIN_API_TOKEN=troque-por-um-token-forte
EXPIRATION_CHECK_INTERVAL_SECONDS=300
DEFAULT_BOT_PERMISSIONS=8
MANAGER_BOT_REGISTER_COMMANDS=true
DATABASE_URL=postgres://usuario:senha@host:5432/bot_manager
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA_PATH=/home/container/database-ca.crt
# DATABASE_SSL_CERT_PATH=/home/container/database-client.pem
# DATABASE_SSL_KEY_PATH=/home/container/database-client.key
SQUARECLOUD_ACCOUNT_ID=coloque_sua_account_id
SQUARECLOUD_API_KEY=coloque_sua_api_key
SQUARECLOUD_API_BASE_URL=https://api.squarecloud.app/v2
SOURCE_ARTIFACTS_DIR=runtime-artifacts
DISCORD_APP_POOL_FILE=data/discord-app-pool.json
SOURCE_ARTIFACT_BOT_TICKET_HYPE=runtime-artifacts/generated/bot-ticket-hype.zip
SOURCE_DISPLAY_NAME_BOT_TICKET_HYPE=Bot Ticket Hype Runtime
SOURCE_MEMORY_BOT_TICKET_HYPE=512
SOURCE_EXCLUDE_PATHS_BOT_TICKET_HYPE=data,transcripts
EFI_CLIENT_ID=coloque_seu_client_id
EFI_CLIENT_SECRET=coloque_seu_client_secret
EFI_PIX_KEY=coloque_sua_chave_pix
EFI_CERT_P12_PATH=/home/container/efi-cert.p12
EFI_SANDBOX=false
EFI_PIX_EXPIRATION_SECONDS=1800
EFI_WEBHOOK_PATH=/webhooks/efipay
EFI_WEBHOOK_SKIP_MTLS=true
EFI_AUTO_SYNC_WEBHOOK=true
BOT_SETUP_TUTORIAL_URL=https://youtu.be/7eamnEDwOW8

# Depois do deploy, o fluxo principal pode ser feito no Discord via /painel-manager e /setpainel.
# A rota /admin/runtime-config continua como fallback tecnico.

# Opcionais:
# MANAGER_BOT_TOKEN=
# MANAGER_BOT_GUILD_ID=
# SOURCE_APP_PUBLIC_URL_BOT_TICKET_HYPE=
# SOURCE_TRANSCRIPT_PUBLIC_URL_BOT_TICKET_HYPE=
# EFI_CERT_P12_PASSPHRASE=
# EFI_CA_PATH=
# DATABASE_SSL_CA_DEPLOY_FILENAME=database-ca.crt
# DATABASE_SSL_CERT_DEPLOY_FILENAME=database-client.pem
# DATABASE_SSL_KEY_DEPLOY_FILENAME=database-client.key
# EFI_BASE_URL=
# EFI_WEBHOOK_PUBLIC_URL=
# EFI_WEBHOOK_SECRET=
# GITHUB_TOKEN=
# SOURCE_GITHUB_REPO_BOT_TICKET_HYPE=hypevalorant/seu-repo-privado
# SOURCE_GITHUB_REF_BOT_TICKET_HYPE=main
# SOURCE_GITHUB_PATH_BOT_TICKET_HYPE=
# SOURCE_GITHUB_TOKEN_BOT_TICKET_HYPE=
